# PostgreSQL connection string.
#   Local docker:  postgres://postgres:postgres@localhost:5432/pickems
#   Railway:       use the DATABASE_URL the Postgres plugin provides
DATABASE_URL="postgres://postgres:postgres@localhost:5432/pickems"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# OPTIONAL: GitHub OAuth provider
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Token used by Vercel Cron to call /api/sync (or send "Authorization: Bearer ...")
CRON_SECRET="generate-with-openssl-rand-base64-32"

# OPTIONAL: Steam Web API key (free at https://steamcommunity.com/dev/apikey)
# Used to fetch persona name + avatar for Steam-signed-in users AND, more
# importantly, to call ICSGOTournaments_730/GetTournamentPredictions on the
# user's behalf when they paste a Major Auth Code (Sync from Steam).
STEAM_API_KEY=""

# Valve event ID for the current Major's Pick'Em — Valve uses its own
# numbering, DIFFERENT from HLTV event ids. e.g. Antwerp 2022 was 15, Rio
# 2022 was 16, etc. Check what the Steam Pick'Em page shows or try a few
# small integers until GetTournamentLayout returns data.
STEAM_PICKEM_EVENT_ID=""

# The HLTV event ID of the Major umbrella (find on hltv.org/events).
# Example (IEM Cologne 2026): 8301
HLTV_EVENT_ID=""

# Per-stage HLTV event IDs — Cologne 2026 splits each Major stage into its
# own HLTV event. Comma-separated KIND:ID pairs. Leave blank for old-format
# Majors (single event).
#   STAGE_1 -> 9028, STAGE_2 -> 9029, STAGE_3 -> ?, PLAYOFFS -> ?
HLTV_STAGE_EVENTS=""
